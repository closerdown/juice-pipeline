pipeline {
    agent any

    triggers {
        githubPush()
    }

    tools {
        "dependency-check" 'dependency-check'
    }

    stages {

        stage('1. Workspace Init') {
            steps {
                sh """
                    rm -rf ${WORKSPACE}/src ${WORKSPACE}/output
                    mkdir -p ${WORKSPACE}/src ${WORKSPACE}/output
                """
            }
        }

        stage('2. Source Code Checkout') {
            steps {
                dir("${WORKSPACE}/src") {
                    git url: 'https://github.com/juice-shop/juice-shop.git', branch: 'master'
                    sh 'ls -la'
                }
            }
        }

        stage('3. Dependency Install') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {
                        docker.image('node:20').inside('--user root') {
                            sh """
                                node --version && npm --version
                                npm install --legacy-peer-deps
                                npm install --package-lock-only --legacy-peer-deps --ignore-scripts
                                cd frontend && npm install --package-lock-only --legacy-peer-deps --ignore-scripts && cd ..
                                npm audit --json > ${WORKSPACE}/output/npm-audit-root.json 2>/dev/null || true
                                cd frontend && npm audit --json > ${WORKSPACE}/output/npm-audit-frontend.json 2>/dev/null || true
                            """
                        }
                    }
                }
            }
        }

        stage('4. Semgrep SAST Scan') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {
                        docker.image('returntocorp/semgrep:latest').inside('--user root') {
                            sh """
                                semgrep --config=auto --json \\
                                    --output=${WORKSPACE}/output/semgrep-result.json \\
                                    . || true
                            """
                        }
                    }
                }
            }
        }

        stage('5. Trivy SCA Scan') {
            steps {
                dir("${WORKSPACE}/src") {
                    script {
                        docker.image('aquasec/trivy:latest').inside('--user root --entrypoint= -v /tmp/trivy-cache:/root/.cache') {
                            sh """
                                trivy fs --scanners vuln --pkg-types library --format json \\
                                    --output ${WORKSPACE}/output/trivy-result.json \\
                                    --severity HIGH,CRITICAL --include-dev-deps --skip-dirs frontend . || true

                                trivy fs --scanners vuln --pkg-types library --format json \\
                                    --output ${WORKSPACE}/output/trivy-frontend-result.json \\
                                    --severity HIGH,CRITICAL --include-dev-deps ./frontend || true

                                trivy fs --scanners vuln --pkg-types library --format json \\
                                    --output ${WORKSPACE}/output/trivy-nodemodules-result.json \\
                                    --severity HIGH,CRITICAL ${WORKSPACE}/src/node_modules || true

                                if [ -f ${WORKSPACE}/src/frontend/dist/bom/bom.json ]; then
                                    trivy sbom --format json \\
                                        --output ${WORKSPACE}/output/trivy-sbom-result.json \\
                                        --severity HIGH,CRITICAL \\
                                        ${WORKSPACE}/src/frontend/dist/bom/bom.json || true
                                fi
                            """
                        }
                    }
                }
            }
        }

        stage('6. OWASP Dependency Check') {
            steps {
                dir("${WORKSPACE}/src") {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        withCredentials([string(credentialsId: 'NVD_API_KEY', variable: 'NVD_KEY')]) {
                            dependencyCheck(
                                odcInstallation: 'dependency-check',
                                additionalArguments: '--nvdApiKey $NVD_KEY --format JSON --format HTML --format XML --out $WORKSPACE/output --scan . --disableYarnAudit --disableOssIndex --data /var/jenkins_home/owasp-data'
                            )
                        }
                    }
                }
            }
        }

        stage('6.5. CVE Merge & Dedup') {
            steps {
                script {
                    def anyTrivy = fileExists("${WORKSPACE}/output/trivy-result.json") ||
                                   fileExists("${WORKSPACE}/output/trivy-frontend-result.json")
                    if (!anyTrivy) {
                        echo "Trivy result missing - skip CVE merge"
                        return
                    }

                    writeFile file: "${WORKSPACE}/output/merge_vulns.py", text: '''
import json, os, re, math
from collections import Counter

WS = os.environ["WORKSPACE"]
TRIVY_FILES = [
    WS + "/output/trivy-result.json",
    WS + "/output/trivy-frontend-result.json",
    WS + "/output/trivy-nodemodules-result.json",
    WS + "/output/trivy-sbom-result.json",
]
OWASP_JSON  = WS + "/output/dependency-check-report.json"
NPM_FILES   = [WS + "/output/npm-audit-root.json", WS + "/output/npm-audit-frontend.json"]
OUTPUT_FILE = WS + "/output/merged_vulns.json"

SEV_MAP = {"critical":"CRITICAL","high":"HIGH","moderate":"MEDIUM","medium":"MEDIUM","low":"LOW","info":"INFO"}

def norm_sev(s):
    return SEV_MAP.get((s or "").lower(), "UNKNOWN")

# ── CVSS v3 vector 파싱 → 점수 계산 ──────────────────────────────────────────
def cvss_v3_from_vector(vector_str):
    """CVSS v3.x vector string → base score (float). 실패 시 None 반환."""
    try:
        if not vector_str or "CVSS:3" not in vector_str:
            return None
        parts = vector_str.split("/")
        # AV, AC, PR, UI, S, C, I, A 순서로 파싱
        m = {}
        for p in parts[1:]:
            if ":" in p:
                k, v = p.split(":", 1)
                m[k] = v

        AV  = {"N": 0.85, "A": 0.62, "L": 0.55, "P": 0.20}.get(m.get("AV","N"), 0.85)
        AC  = {"L": 0.77, "H": 0.44}.get(m.get("AC","L"), 0.77)
        PR_scope = m.get("S","U")
        PR_map = {"N": {"U":0.85,"C":0.85}, "L": {"U":0.62,"C":0.68}, "H": {"U":0.27,"C":0.50}}
        PR  = PR_map.get(m.get("PR","N"), {"U":0.85,"C":0.85}).get(PR_scope, 0.85)
        UI  = {"N": 0.85, "R": 0.62}.get(m.get("UI","N"), 0.85)
        SC  = {"N": 0.00, "L": 0.22, "H": 0.56}.get(m.get("C","N"), 0.00)
        SI  = {"N": 0.00, "L": 0.22, "H": 0.56}.get(m.get("I","N"), 0.00)
        SA  = {"N": 0.00, "L": 0.22, "H": 0.56}.get(m.get("A","N"), 0.00)

        ISS = 1 - (1 - SC) * (1 - SI) * (1 - SA)
        if PR_scope == "U":
            Impact = 6.42 * ISS
        else:
            Impact = 7.52 * (ISS - 0.029) - 3.25 * math.pow(ISS - 0.02, 15)

        Exploitability = 8.22 * AV * AC * PR * UI

        if Impact <= 0:
            BaseScore = 0.0
        else:
            if PR_scope == "U":
                BaseScore = min((Impact + Exploitability), 10)
            else:
                BaseScore = min(1.08 * (Impact + Exploitability), 10)

        # 올림 처리 (소수점 1자리)
        BaseScore = math.ceil(BaseScore * 10) / 10
        return round(BaseScore, 1)
    except Exception:
        return None

def parse_trivy(paths):
    vulns = {}
    for path in paths:
        if not os.path.exists(path):
            continue
        with open(path, encoding="utf-8", errors="replace") as f:
            data = json.load(f)
        for result in data.get("Results", []):
            for v in result.get("Vulnerabilities") or []:
                vid = v.get("VulnerabilityID")
                if not vid:
                    continue
                cvss = None
                cvss_source = "missing"
                for src in (v.get("CVSS") or {}).values():
                    val = float(src.get("V3Score") or src.get("V2Score") or 0)
                    if val > 0:
                        cvss = max(cvss, val) if cvss is not None else val
                        cvss_source = "trivy"
                prev = vulns.get(vid)
                if prev is None or (cvss is not None and (prev["cvss"] is None or cvss > prev["cvss"])):
                    vulns[vid] = {
                        "vuln_id": vid,
                        "package": v.get("PkgName", ""),
                        "version": v.get("InstalledVersion", ""),
                        "severity": v.get("Severity", "UNKNOWN"),
                        "cvss": cvss,
                        "cvss_source": cvss_source,
                        "source": "trivy"
                    }
    print("[Trivy] " + str(len(vulns)) + " entries")
    return vulns

def parse_owasp_json(path):
    vulns = {}
    if not os.path.exists(path):
        print("[OWASP] JSON 파일 없음 — 스킵")
        return vulns
    with open(path, encoding="utf-8", errors="replace") as f:
        try:
            data = json.load(f)
        except json.JSONDecodeError:
            print("[OWASP] JSON 파싱 오류")
            return vulns
    sev_map = {"CRITICAL":"CRITICAL","HIGH":"HIGH","MEDIUM":"MEDIUM","MODERATE":"MEDIUM","LOW":"LOW","INFO":"INFO"}
    for dep in data.get("dependencies", []):
        pkg = dep.get("fileName", "unknown")
        for vuln in dep.get("vulnerabilities", []):
            vid = vuln.get("name", "")
            if not vid:
                continue
            sev = sev_map.get(vuln.get("severity", "").upper(), "UNKNOWN")
            cvss = None
            cvss_source = "missing"
            for key in ["cvssv3", "cvssV3", "cvss3"]:
                cvssv3 = vuln.get(key) or {}
                for score_key in ["baseScore", "score"]:
                    val = cvssv3.get(score_key)
                    if val is not None:
                        try:
                            f = float(val)
                            if f > 0:
                                cvss = f
                                cvss_source = "owasp_v3"
                                break
                        except (ValueError, TypeError):
                            pass
                if cvss:
                    break
            if not cvss:
                for key in ["cvssv2", "cvssV2", "cvss2"]:
                    cvssv2 = vuln.get(key) or {}
                    for score_key in ["score", "baseScore"]:
                        val = cvssv2.get(score_key)
                        if val is not None:
                            try:
                                f = float(val)
                                if f > 0:
                                    cvss = f
                                    cvss_source = "owasp_v2"
                                    break
                            except (ValueError, TypeError):
                                pass
                    if cvss:
                        break
            prev = vulns.get(vid)
            if prev is None or (cvss is not None and (prev["cvss"] is None or cvss > prev["cvss"])):
                vulns[vid] = {
                    "vuln_id": vid, "package": pkg, "version": "",
                    "severity": sev, "cvss": cvss, "cvss_source": cvss_source, "source": "owasp"
                }
    print("[OWASP] " + str(len(vulns)) + " entries")
    return vulns

def parse_npm(paths):
    vulns = {}
    for path in paths:
        if not os.path.exists(path):
            continue
        with open(path, encoding="utf-8", errors="replace") as f:
            try:
                data = json.load(f)
            except json.JSONDecodeError:
                continue
        for pkg_name, info in (data.get("vulnerabilities") or {}).items():
            sev = norm_sev(info.get("severity", ""))
            for via in (info.get("via") or []):
                if not isinstance(via, dict):
                    continue
                vid = via.get("cve", "")
                if not vid:
                    url = via.get("url", "")
                    if "GHSA-" in url:
                        vid = "GHSA-" + url.split("GHSA-")[-1].split("/")[0]
                    elif via.get("source"):
                        vid = "NPM-" + str(via.get("source"))
                    else:
                        continue
                raw_score = float((via.get("cvss") or {}).get("score") or 0)
                cvss = raw_score if raw_score > 0 else None
                cvss_source = "npm" if cvss else "missing"
                prev = vulns.get(vid)
                if prev is None or (cvss is not None and (prev["cvss"] is None or cvss > prev["cvss"])):
                    vulns[vid] = {
                        "vuln_id": vid, "package": pkg_name, "version": info.get("range", ""),
                        "severity": sev, "cvss": cvss, "cvss_source": cvss_source, "source": "npm"
                    }
    print("[npm] " + str(len(vulns)) + " entries")
    return vulns

def merge(trivy, owasp, npm):
    merged = []
    for vid in sorted(set(trivy) | set(owasp) | set(npm)):
        sources, entry = [], None
        for d, label in [(trivy,"trivy"),(npm,"npm"),(owasp,"owasp")]:
            if vid in d:
                sources.append(label)
                if entry is None:
                    entry = d[vid].copy()
                else:
                    a, b = entry["cvss"], d[vid]["cvss"]
                    if a is None and b is not None:
                        entry["cvss"] = b
                        entry["cvss_source"] = d[vid]["cvss_source"]
                    elif a is not None and b is not None and b > a:
                        entry["cvss"] = b
                        entry["cvss_source"] = d[vid]["cvss_source"]
        entry["source"] = "+".join(sources)
        entry["source_count"] = len(sources)
        merged.append(entry)
    merged.sort(key=lambda x: x["cvss"] if x["cvss"] is not None else -1, reverse=True)
    return merged

def fetch_osv(vuln_id):
    """OSV API 조회 — CVSS 숫자 또는 vector 반환"""
    import urllib.request
    try:
        url = "https://api.osv.dev/v1/vulns/" + vuln_id
        req = urllib.request.Request(url, headers={"User-Agent": "juice-pipeline/1.0"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read().decode("utf-8"))

        # 1) database_specific 숫자 점수
        db = data.get("database_specific", {})
        for key in ["cvss_score", "cvss", "severity_score"]:
            score = db.get(key)
            if score:
                try:
                    f = float(score)
                    if f > 0:
                        return f, "osv_db"
                except (ValueError, TypeError):
                    pass

        # 2) affected[].database_specific 숫자 점수
        for aff in data.get("affected", []):
            db2 = aff.get("database_specific", {})
            for key in ["cvss_score", "cvss"]:
                score2 = db2.get(key)
                if score2:
                    try:
                        f = float(score2)
                        if f > 0:
                            return f, "osv_db"
                    except (ValueError, TypeError):
                        pass

        # 3) severity[].score 숫자
        for sev in data.get("severity", []):
            raw = sev.get("score", "")
            try:
                f = float(raw)
                if f > 0:
                    return f, "osv_score"
            except (ValueError, TypeError):
                pass
            # vector string → 계산
            if isinstance(raw, str) and "CVSS:3" in raw:
                calc = cvss_v3_from_vector(raw)
                if calc and calc > 0:
                    return calc, "osv_vector"

        return None, None
    except Exception:
        return None, None

def enrich_cvss(merged):
    """CVSS 없는 항목을 OSV API로 보완 (vector 파싱 포함)"""
    targets = [v for v in merged if v["cvss"] is None
               and (v["vuln_id"].startswith("GHSA-") or
                    v["vuln_id"].startswith("CVE-") or
                    v["vuln_id"].startswith("NSWG-"))]

    if not targets:
        print("[OSV] CVSS 없는 항목 없음 — 스킵")
        return merged

    print("[OSV] CVSS 보완 시도: " + str(len(targets)) + "개")
    hit, miss = 0, 0
    for v in targets:
        score, src = fetch_osv(v["vuln_id"])
        if score and score > 0:
            v["cvss"] = score
            v["cvss_source"] = src
            hit += 1
            print("[OSV] " + v["vuln_id"] + " → " + str(score) + " (" + src + ")")
        else:
            v["cvss_source"] = "missing"
            miss += 1

    print("[OSV] 보완 성공: " + str(hit) + "개 / 실패: " + str(miss) + "개")
    merged.sort(key=lambda x: x["cvss"] if x["cvss"] is not None else -1, reverse=True)
    return merged

trivy  = parse_trivy(TRIVY_FILES)
owasp  = parse_owasp_json(OWASP_JSON)
npm    = parse_npm(NPM_FILES)
merged = merge(trivy, owasp, npm)
print("[merged] total=" + str(len(merged)))

merged = enrich_cvss(merged)

none_count = sum(1 for v in merged if v["cvss"] is None)
print("[CVSS 없음] 최종 " + str(none_count) + "개 (cvss_source=missing)")

with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
    json.dump(merged, f, indent=2, ensure_ascii=False)
print("[저장] " + OUTPUT_FILE)

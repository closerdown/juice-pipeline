                                                              'promo', 'discount-code']],
                            security : [score: 3, keywords: ['sanitize', 'sanitize-html', 'xss', 'escape',
                                                              'helmet', 'validator', 'dompurify', 'marked',
                                                              'sql', 'inject']],
                            product  : [score: 2, keywords: ['product', 'item', 'catalog', 'search',
                                                              'list', 'category']]
                        ]

                        def categoryOrder = ['payment','auth','admin','inventory','sandbox',
                                             'personal','coupon','security','product']

                        def TRUST_WEIGHTS = [1.0, 1.0, 1.15, 1.30]
                        def MAX_RAW       = 96.0

                        def publicRoutes    = []
                        def semgrepFindings = []

                        if (fileExists("${WORKSPACE}/output/semgrep-result.json")) {
                            def semgrepJson = readJSON file: "${WORKSPACE}/output/semgrep-result.json"
                            semgrepJson.results?.each { finding ->
                                def msg  = finding.extra?.message?.toLowerCase() ?: ''
                                def rule = finding.check_id?.toLowerCase() ?: ''
                                def file = finding.path?.toLowerCase() ?: ''
                                semgrepFindings.add([file: finding.path, rule: rule, message: msg])
                                if (msg.contains('/api/') || msg.contains('/rest/') ||
                                    file.contains('route') || file.contains('router') ||
                                    rule.contains('route') || rule.contains('express')) {
                                    publicRoutes.add(msg)
                                }
                            }
                            echo "Semgrep routes: ${publicRoutes.size()}"
                        }

                        def swaggerEndpoints   = []
                        def swaggerPublicPaths = []
                        if (fileExists("${WORKSPACE}/output/swagger-analysis.json")) {
                            def swaggerJson = readJSON file: "${WORKSPACE}/output/swagger-analysis.json"
                            swaggerEndpoints = swaggerJson.endpoints ?: []
                            swaggerEndpoints.each { ep -> swaggerPublicPaths.add(ep.path?.toLowerCase() ?: '') }
                            echo "Swagger endpoints: ${swaggerEndpoints.size()}"
                        }

                        def vulnBusinessScores = []

                        def sourceFiles = fileExists("${WORKSPACE}/output/merged_vulns.json")
                            ? ["${WORKSPACE}/output/merged_vulns.json"]
                            : ["${WORKSPACE}/output/trivy-result.json",
                               "${WORKSPACE}/output/trivy-frontend-result.json"]

                        sourceFiles.each { filePath ->
                            if (!fileExists(filePath)) return
                            def vulnList = []

                            if (filePath.contains("merged_vulns")) {
                                vulnList = readJSON file: filePath
                            } else {
                                def trivyJson = readJSON file: filePath
                                trivyJson.Results?.each { result ->
                                    result.Vulnerabilities?.each { v ->
                                        def cvss = 0.0
                                        if (v.CVSS) {
                                            ['nvd','ghsa','redhat'].each { src ->
                                                if (v.CVSS[src] && cvss == 0.0) {
                                                    def v3 = v.CVSS[src]?.V3Score
                                                    def v2 = v.CVSS[src]?.V2Score
                                                    if (v3 != null) cvss = v3 as double
                                                    else if (v2 != null) cvss = v2 as double
                                                }
                                            }
                                        }
                                        vulnList.add([vuln_id:v.VulnerabilityID?:'', package:v.PkgName?:'',
                                            version:v.InstalledVersion?:'', severity:v.Severity?:'',
                                            cvss: cvss > 0.0 ? cvss : null,
                                            cvss_source: cvss > 0.0 ? 'trivy' : 'missing',
                                            source:'trivy', source_count:1])
                                    }
                                }
                            }

                            vulnList.each { vuln ->
                                def rawCvss   = vuln.cvss
                                def cvssScore = null
                                try {
                                    if (rawCvss != null && !(rawCvss instanceof net.sf.json.JSONNull))
                                        cvssScore = rawCvss as double
                                } catch (Exception e) { cvssScore = null }

                                def pkgName     = (vuln.package ?: '').toLowerCase()
                                def bizScore    = 0
                                def bizCategory = 'internal'
                                def matchedKw   = ''

                                for (int ci = 0; ci < categoryOrder.size(); ci++) {
                                    if (bizScore > 0) break
                                    def cat    = categoryOrder[ci]
                                    def config = businessKeywords[cat]
                                    for (int ki = 0; ki < config.keywords.size(); ki++) {
                                        def kw = config.keywords[ki]
                                        if (kw.length() >= 3 && pkgName.contains(kw)) {
                                            bizScore = config.score; bizCategory = cat; matchedKw = kw; break
                                        }
                                    }
                                }

                                if (publicRoutes.any { r -> r.contains(pkgName) } ||
                                    swaggerPublicPaths.any { pt -> pt.contains(pkgName) }) bizScore += 2

                                def swaggerBonus = 0
                                swaggerEndpoints.each { ep ->
                                    def epPath = (ep.path ?: '').toLowerCase()
                                    if (pkgName.length() >= 4 && epPath.contains(pkgName)) {
                                        def epBiz = (ep.biz_score != null) ? (ep.biz_score as int) : 0
                                        if (epBiz > swaggerBonus) swaggerBonus = epBiz
                                    }
                                }
                                if (swaggerBonus > bizScore) { bizScore = swaggerBonus; bizCategory = 'swagger-mapped' }

                                def reachability = 1.0
                                if (pkgName.length() >= 4 && semgrepFindings.any { f ->
                                    f.message?.contains(pkgName) || f.rule?.contains(pkgName) || f.file?.contains(pkgName)
                                }) reachability = 1.5

                                def srcCount    = (vuln.source_count != null) ? (vuln.source_count as int) : 1
                                def trustWeight = TRUST_WEIGHTS[Math.min(srcCount, TRUST_WEIGHTS.size()-1)] as double
                                def effectiveBiz = bizScore > 0 ? bizScore : 2

                                // CVSS 없으면 finalScore 계산 불가 → null 처리
                                def rawScore  = null
                                def finalScore = null
                                def gate = 'Unknown'
                                if (cvssScore != null) {
                                    rawScore   = cvssScore * reachability * effectiveBiz * trustWeight
                                    finalScore = Math.min((rawScore / MAX_RAW) * 20.0 as double, 20.0 as double)
                                    gate = finalScore >= 14.0 ? 'Block' : finalScore >= 8.0 ? 'Warn' : 'Pass'
                                }

                                // 연결 API (bizCategory 기반)
                                def connectedApis = []
                                if (bizCategory != 'internal') {
                                    swaggerEndpoints.each { ep ->
                                        if ((ep.biz_category == bizCategory) &&
                                            (ep.biz_score != null && (ep.biz_score as int) > 0) &&
                                            connectedApis.size() < 3) {
                                            connectedApis.add(ep.path + " [" + ep.method + "]")
                                        }
                                    }
                                    if (connectedApis.isEmpty() && matchedKw) {
                                        swaggerEndpoints.each { ep ->
                                            def epPath = (ep.path ?: '').toLowerCase()
                                            if (matchedKw.length() >= 3 && epPath.contains(matchedKw) &&
                                                connectedApis.size() < 3) {
                                                connectedApis.add(ep.path + " [" + ep.method + "]")
                                            }
                                        }
                                    }
                                }

                                // Semgrep 파일
                                def semgrepFiles = []
                                semgrepFindings.each { f ->
                                    if (pkgName.length() >= 4 &&
                                        (f.message?.contains(pkgName) || f.file?.contains(pkgName))) {
                                        def filePath2 = f.file ?: ''
                                        if (filePath2 && !semgrepFiles.contains(filePath2))
                                            semgrepFiles.add(filePath2)
                                    }
                                }

                                vulnBusinessScores.add([
                                    pkg          : vuln.package ?: '',
                                    version      : vuln.version ?: '',
                                    cve          : vuln.vuln_id ?: '',
                                    severity     : vuln.severity ?: '',
                                    cvss         : cvssScore,
                                    cvss_source  : vuln.cvss_source ?: 'missing',
                                    bizCategory  : bizCategory,
                                    bizScore     : bizScore,
                                    matchedKw    : matchedKw,
                                    reachability : reachability,
                                    trustWeight  : trustWeight,
                                    sourceCount  : srcCount,
                                    rawScore     : rawScore,
                                    finalScore   : finalScore,
                                    gate         : gate,
                                    source       : vuln.source ?: '',
                                    connectedApis: connectedApis,
                                    semgrepFiles : semgrepFiles
                                ])
                            }
                        }

                        def n = vulnBusinessScores.size()
                        for (int i = 0; i < n-1; i++)
                            for (int j = 0; j < n-i-1; j++) {
                                def fj  = vulnBusinessScores[j].finalScore
                                def fj1 = vulnBusinessScores[j+1].finalScore
                                def vj  = fj  != null ? (fj  as double) : -1.0
                                def vj1 = fj1 != null ? (fj1 as double) : -1.0
                                if (vj < vj1) {
                                    def tmp = vulnBusinessScores[j]
                                    vulnBusinessScores[j] = vulnBusinessScores[j+1]
                                    vulnBusinessScores[j+1] = tmp
                                }
                            }

                        def top10 = vulnBusinessScores.take(10)
                        echo "====== TOP 10 ======"
                        top10.eachWithIndex { v, i ->
                            def fs = v.finalScore != null ? String.format('%.2f', v.finalScore as double) : 'N/A'
                            echo "${i+1}. ${v.cve} | ${v.pkg}@${v.version} | CVSS:${v.cvss}(${v.cvss_source}) | ${v.bizCategory}(+${v.bizScore}) | final:${fs}/20 | ${v.gate}"
                        }

                        def blockCount   = vulnBusinessScores.count { it.gate == 'Block' }
                        def warnCount    = vulnBusinessScores.count { it.gate == 'Warn' }
                        def passCount    = vulnBusinessScores.count { it.gate == 'Pass' }
                        def unknownCount = vulnBusinessScores.count { it.gate == 'Unknown' }
                        echo "Block:${blockCount} Warn:${warnCount} Pass:${passCount} Unknown(CVSS없음):${unknownCount}"

                        writeJSON file: "${WORKSPACE}/output/business-risk-result.json", json: vulnBusinessScores
                        echo "Business Context Analysis done"
                    }
                }
            }
        }

        stage('8. Risk Scoring & Gate') {
            steps {
                script {
                    def semgrepCount = 0, mergedHigh = 0, mergedCrit = 0
                    def maxFinal = 0.0, blockCount = 0, warnCount = 0

                    if (fileExists("${WORKSPACE}/output/semgrep-result.json")) {
                        def semJson = readJSON file: "${WORKSPACE}/output/semgrep-result.json"
                        semgrepCount = semJson.results?.size() ?: 0
                    }

                    if (fileExists("${WORKSPACE}/output/merged_vulns.json")) {
                        def mergedJson = readJSON file: "${WORKSPACE}/output/merged_vulns.json"
                        mergedJson.each { v ->
                            def sev = (v.severity ?: '').toUpperCase()
                            if (sev == 'HIGH') mergedHigh++
                            if (sev == 'CRITICAL') mergedCrit++
                        }
                    }

                    if (fileExists("${WORKSPACE}/output/business-risk-result.json")) {
                        def bizJson = readJSON file: "${WORKSPACE}/output/business-risk-result.json"
                        bizJson.each { v ->
                            def s = 0.0
                            try {
                                def raw = v.finalScore
                                if (raw != null && !(raw instanceof net.sf.json.JSONNull))
                                    s = raw as double
                            } catch (Exception e) { s = 0.0 }
                            if (s > maxFinal) maxFinal = s
                            if (s >= 14.0) blockCount++
                            else if (s >= 8.0) warnCount++
                        }
                    }

                    def swaggerHR = 0
                    if (fileExists("${WORKSPACE}/output/swagger-analysis.json")) {
                        def swaggerJson = readJSON file: "${WORKSPACE}/output/swagger-analysis.json"
                        swaggerHR = swaggerJson.summary?.high_risk?.size() ?: 0
                    }

                    def total = mergedHigh + mergedCrit
                    def critR = total > 0 ? (mergedCrit / total as double) : 0.0
                    def highR = total > 0 ? (mergedHigh  / total as double) : 0.0
                    def base  = (critR * 100) + (highR * 40) + (semgrepCount * 0.2)

                    def baseGrade, baseAction, baseReason
                    if (base >= 60.0) {
                        baseGrade  = "HIGH RISK"
                        baseAction = "BLOCK"
                        baseReason = "Base score exceeded deployment threshold (>= 60)"
                    } else if (base >= 40.0) {
                        baseGrade  = "WARN"
                        baseAction = "ALLOW"
                        baseReason = "Elevated base score. Security review recommended."
                    } else {
                        baseGrade  = "PASS"
                        baseAction = "ALLOW"
                        baseReason = "Base score within acceptable range."
                    }

                    def bizGrade, bizAction, bizReason
                    if (blockCount > 0) {
                        bizGrade  = "CRITICAL BLOCK"
                        bizAction = "BLOCK"
                        bizReason = "Business-critical vulnerability detected (finalScore >= 14/20)"
                    } else if (warnCount > 0) {
                        bizGrade  = "WARN"
                        bizAction = "ALLOW"
                        bizReason = "High business risk vulnerability detected (finalScore >= 8/20)"
                    } else {
                        bizGrade  = "PASS"
                        bizAction = "ALLOW"
                        bizReason = "Business risk within acceptable range."
                    }

                    echo "======================================================"
                    echo "  [Base Score Gate]"
                    echo "  Risk Score : ${String.format('%.1f', base)}/100"
                    echo "  Status     : ${baseGrade}"
                    echo "  Action     : ${baseAction}"
                    echo "  Reason     : ${baseReason}"
                    echo "------------------------------------------------------"
                    echo "  [Business Risk Gate]"
                    echo "  Max Score  : ${String.format('%.2f', maxFinal)}/20"
                    echo "  Status     : ${bizGrade}"
                    echo "  Action     : ${bizAction}"
                    echo "  Reason     : ${bizReason}"
                    echo "  Block:${blockCount} Warn:${warnCount}"
                    echo "  Swagger High Risk Endpoints: ${swaggerHR}"
                    echo "======================================================"

                    if (bizAction == "BLOCK" || baseAction == "BLOCK") {
                        currentBuild.result = 'FAILURE'
                        echo "BLOCKED — Build failed due to security policy violation"
                    } else if (baseGrade == "WARN" || bizGrade == "WARN") {
                        currentBuild.result = 'UNSTABLE'
                        echo "WARN — Security review required before release"
                    } else {
                        echo "PASS — All security gates passed"
                    }
                }
            }
        }

        stage('8.5. CVSS-Only Gate Simulation') {
            steps {
                script {
                    if (!fileExists("${WORKSPACE}/output/business-risk-result.json")) {
                        echo "business-risk-result.json 없음 - skip"
                        return
                    }

                    def bizJson    = readJSON file: "${WORKSPACE}/output/business-risk-result.json"
                    def upgraded   = []  // CVSS로는 못 잡는데 우리가 Block한 것
                    def downgraded = []  // CVSS로는 Block인데 우리는 Pass (과잉 차단 방지)
                    def unknown    = []  // CVSS 없어서 판단 불가

                    bizJson.each { v ->
                        def cvss = null
                        try {
                            def raw = v.cvss
                            if (raw != null && !(raw instanceof net.sf.json.JSONNull))
                                cvss = raw as double
                        } catch (Exception e) { cvss = null }

                        def bizGate = v.gate ?: 'Unknown'

                        // CVSS 없으면 Unknown 분리
                        if (cvss == null) {
                            unknown.add([
                                cve    : v.cve         ?: '',
                                pkg    : v.pkg         ?: '',
                                bizGate: bizGate,
                                bizCat : v.bizCategory ?: '',
                                final  : v.finalScore
                            ])
                            return
                        }

                        def cvssGate = cvss >= 9.0 ? 'Block' :
                                       cvss >= 7.0 ? 'Warn'  : 'Pass'

                        if (cvssGate != 'Block' && bizGate == 'Block') {
                            upgraded.add([
                                cve          : v.cve          ?: '',
                                pkg          : v.pkg          ?: '',
                                cvss         : cvss,
                                cvss_source  : v.cvss_source  ?: 'missing',
                                cvssGate     : cvssGate,
                                bizGate      : bizGate,
                                bizScore     : v.bizScore     ?: 0,
                                bizCat       : v.bizCategory  ?: '',
                                reach        : v.reachability ?: 1.0,
                                final        : v.finalScore   ?: 0.0,
                                connectedApis: v.connectedApis ?: [],
                                semgrepFiles : v.semgrepFiles  ?: []
                            ])
                        }

                        if (cvssGate == 'Block' && bizGate == 'Pass') {
                            downgraded.add([
                                cve        : v.cve         ?: '',
                                pkg        : v.pkg         ?: '',
                                cvss       : cvss,
                                cvss_source: v.cvss_source ?: 'missing',
                                cvssGate   : cvssGate,
                                bizGate    : bizGate,
                                bizScore   : v.bizScore    ?: 0,
                                bizCat     : v.bizCategory ?: '',
                                reach      : v.reachability ?: 1.0,
                                final      : v.finalScore  ?: 0.0
                            ])
                        }
                    }

                    echo "====== CVSS vs Business Risk 비교 ======"
                    echo "[우리가 추가로 잡은 Block] ${upgraded.size()}개"
                    upgraded.each { v ->
                        echo "  ${v.cve} | ${v.pkg} | CVSS:${v.cvss}(${v.cvssGate}) → BizRisk:${String.format('%.2f', v.final as double)}점(${v.bizGate}) | ${v.bizCat}(×${v.bizScore}) reach:${v.reach}"
                        if (v.connectedApis) echo "    연결 API: ${v.connectedApis}"
                        if (v.semgrepFiles)  echo "    Semgrep 파일: ${v.semgrepFiles}"
                    }
                    echo ""
                    echo "[과잉 차단 방지 — CVSS Block → 우리는 Pass] ${downgraded.size()}개"
                    downgraded.each { v ->
                        echo "  ${v.cve} | ${v.pkg} | CVSS:${v.cvss}(${v.cvssGate}) → BizRisk:${String.format('%.2f', v.final as double)}점(${v.bizGate}) | ${v.bizCat}(×${v.bizScore})"
                    }
                    echo ""
                    echo "[CVSS 없어 판단 불가 — Unknown] ${unknown.size()}개"
                    unknown.each { v ->
                        echo "  ${v.cve} | ${v.pkg} | BizGate:${v.bizGate} | ${v.bizCat}"
                    }
                    echo "========================================"

                    writeJSON file: "${WORKSPACE}/output/cvss-comparison.json",
                              json: [
                                  upgraded  : upgraded,
                                  downgraded: downgraded,
                                  unknown   : unknown,
                                  summary   : [
                                      upgraded_count  : upgraded.size(),
                                      downgraded_count: downgraded.size(),
                                      unknown_count   : unknown.size()
                                  ]
                              ]
                }
            }
        }

        stage('9. Prometheus Push') {
            steps {
                script {
                    def bizJson     = fileExists("${WORKSPACE}/output/business-risk-result.json")
                        ? readJSON(file: "${WORKSPACE}/output/business-risk-result.json") : []
                    def mergedJson  = fileExists("${WORKSPACE}/output/merged_vulns.json")
                        ? readJSON(file: "${WORKSPACE}/output/merged_vulns.json") : []
                    def semgrepJson = fileExists("${WORKSPACE}/output/semgrep-result.json")
                        ? readJSON(file: "${WORKSPACE}/output/semgrep-result.json") : [results:[]]

                    def crit=0, high=0, block=0, warn=0, maxS=0.0

                    mergedJson.each { v ->
                        def sev = (v.severity?:'').toUpperCase()
                        if (sev=='CRITICAL') crit++
                        if (sev=='HIGH') high++
                    }
                    bizJson.each { v ->
                        def s = 0.0
                        try {
                            def raw = v.finalScore
                            if (raw != null && !(raw instanceof net.sf.json.JSONNull))
                                s = raw as double
                        } catch (Exception e) { s = 0.0 }
                        if (s > maxS) maxS = s
                        if (s >= 14.0) block++
                        else if (s >= 8.0) warn++
                    }

                    def sc   = semgrepJson.results?.size() ?: 0
                    def tot  = crit + high
                    def cR   = tot > 0 ? (crit/tot as double) : 0.0
                    def hR   = tot > 0 ? (high/tot as double) : 0.0
                    def base = (cR*100)+(hR*40)+(sc*0.2)

                    def upgradedCount   = 0
                    def downgradedCount = 0
                    def unknownCount    = 0
                    if (fileExists("${WORKSPACE}/output/cvss-comparison.json")) {
                        def compJson = readJSON file: "${WORKSPACE}/output/cvss-comparison.json"
                        upgradedCount   = compJson.summary?.upgraded_count   ?: 0
                        downgradedCount = compJson.summary?.downgraded_count ?: 0
                        unknownCount    = compJson.summary?.unknown_count    ?: 0
                    }

                    def metrics = """# HELP trivy_pipe_risk_score Business Risk Score (20점 기준)
# TYPE trivy_pipe_risk_score gauge
trivy_pipe_risk_score ${String.format('%.2f',maxS)}
# HELP trivy_pipe_base_score Base Score
# TYPE trivy_pipe_base_score gauge
trivy_pipe_base_score ${String.format('%.1f',base)}
# HELP trivy_pipe_critical_count CRITICAL count
# TYPE trivy_pipe_critical_count gauge
trivy_pipe_critical_count ${crit}
# HELP trivy_pipe_high_count HIGH count
# TYPE trivy_pipe_high_count gauge
trivy_pipe_high_count ${high}
# HELP trivy_pipe_total_vulns total vulns
# TYPE trivy_pipe_total_vulns gauge
trivy_pipe_total_vulns ${mergedJson.size()}
# HELP trivy_pipe_block_count block count
# TYPE trivy_pipe_block_count gauge
trivy_pipe_block_count ${block}
# HELP trivy_pipe_warn_count warn count
# TYPE trivy_pipe_warn_count gauge
trivy_pipe_warn_count ${warn}
# HELP trivy_pipe_semgrep_count semgrep count
# TYPE trivy_pipe_semgrep_count gauge
trivy_pipe_semgrep_count ${sc}
# HELP trivy_pipe_build_status build status (1=pass, 0=fail)
# TYPE trivy_pipe_build_status gauge
trivy_pipe_build_status ${block > 0 || base >= 60.0 ? 0 : 1}
# HELP trivy_pipe_cvss_upgraded_count CVSS로는 못 잡는데 BizRisk로 추가 Block한 수
# TYPE trivy_pipe_cvss_upgraded_count gauge
trivy_pipe_cvss_upgraded_count ${upgradedCount}
# HELP trivy_pipe_cvss_downgraded_count CVSS Block → BizRisk Pass (과잉 차단 방지)
# TYPE trivy_pipe_cvss_downgraded_count gauge
trivy_pipe_cvss_downgraded_count ${downgradedCount}
# HELP trivy_pipe_cvss_unknown_count CVSS 없어 판단 불가
# TYPE trivy_pipe_cvss_unknown_count gauge
trivy_pipe_cvss_unknown_count ${unknownCount}
"""
                    writeFile file: "${WORKSPACE}/output/metrics.txt", text: metrics
                    sh """
                        curl -s -X POST \\
                            http://pushgateway:9091/metrics/job/trivy-pipe/instance/juice-shop \\
                            --data-binary @${WORKSPACE}/output/metrics.txt \\
                        && echo "Prometheus push OK" || echo "Prometheus push FAILED"
                    """
                }
            }
        }

        stage('10. Security Metrics Push') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    script {
                        sh """
                            if ! python3 -c "import prometheus_client" 2>/dev/null; then
                                apt-get update -qq 2>/dev/null || true
                                apt-get install -y -q python3-pip 2>/dev/null || true
                                python3 -m pip install prometheus_client --break-system-packages -q
                            fi
                            cp ${WORKSPACE}/security_metrics.py ${WORKSPACE}/output/security_metrics.py
                            WORKSPACE=${WORKSPACE} PUSHGATEWAY_URL=pushgateway:9091 \\
                                python3 ${WORKSPACE}/output/security_metrics.py
                        """
                    }
                }
            }
        }

    } // end stages

    post {
        always {
            archiveArtifacts artifacts: 'output/**', allowEmptyArchive: true
            script {
                if (fileExists('output/dependency-check-report.xml'))
                    dependencyCheckPublisher pattern: 'output/dependency-check-report.xml'
                else
                    echo "OWASP report missing - skip publisher"
            }
            echo "Result: ${currentBuild.currentResult}"
        }
        success { echo "✅ Pipeline SUCCESS — All security gates passed" }
        failure { echo "❌ Pipeline FAILURE — Security policy violation detected" }
        unstable { echo "⚠️ Pipeline UNSTABLE — Security review required" }
    }
}

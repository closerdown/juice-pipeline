                        sh "rm -f ${WORKSPACE}/output/swagger-analysis.json"

                        writeFile file: "${WORKSPACE}/output/parse_swagger.py", text: '''
import json, os, re, sys

try:
    import yaml
except ImportError:
    import subprocess
    try:
        subprocess.run(["apt-get","install","-y","-q","python3-yaml"], check=True, capture_output=True)
    except Exception:
        subprocess.run([sys.executable,"-m","pip","install","pyyaml","--break-system-packages","-q"], check=True)
    import yaml

WS           = os.environ["WORKSPACE"]
SWAGGER_FILE = WS + "/src/swagger.yml"
OUTPUT_FILE  = WS + "/output/swagger-analysis.json"

BIZ_CATEGORIES = [
    {"name":"payment",  "score":5,"keywords":["pay","payment","checkout","purchase","billing","charge","refund","transaction","pg","card","bank","stripe","invoice","order","orders"]},
    {"name":"auth",     "score":4,"keywords":["auth","login","logout","register","signup","password","token","oauth","session","credential","jwt","saml"]},
    {"name":"admin",    "score":4,"keywords":["admin","manager","dashboard","console","superuser","root","config","setting"]},
    {"name":"inventory","score":4,"keywords":["price","stock","inventory","quantity","discount","product-edit"]},
    {"name":"sandbox",  "score":4,"keywords":["vm","sandbox","eval","execute","template"]},
    {"name":"personal", "score":3,"keywords":["user","profile","personal","privacy","email","phone","address","delivery","shipping","ssn","kyc"]},
    {"name":"coupon",   "score":3,"keywords":["coupon","point","voucher","reward","promo"]},
    {"name":"security", "score":3,"keywords":["sanitize","xss","escape","helmet","validator","sql","inject"]},
    {"name":"product",  "score":1,"keywords":["product","item","catalog","search","list","category"]},
]
PUBLIC_METHODS = {"get","post","put","patch","delete"}

def get_biz_score(path_str):
    p = path_str.lower()
    for cat in BIZ_CATEGORIES:
        for kw in cat["keywords"]:
            if len(kw) >= 3 and kw in p:
                return cat["score"], cat["name"], kw
    return 0, "internal", ""

with open(SWAGGER_FILE, encoding="utf-8") as f:
    spec = yaml.safe_load(f)

base_path = (spec.get("basePath") or "").rstrip("/")
paths     = spec.get("paths") or {}
endpoints = []
summary   = {"total":0,"by_category":{},"by_method":{},"high_risk":[]}

for path, path_item in paths.items():
    if not isinstance(path_item, dict):
        continue
    for method, operation in path_item.items():
        if method.lower() not in PUBLIC_METHODS or not isinstance(operation, dict):
            continue
        full_path = base_path + path
        biz_score, biz_cat, matched_kw = get_biz_score(full_path)
        total_score = biz_score + 2
        entry = {
            "path":full_path,"method":method.upper(),
            "summary":operation.get("summary",""),"tags":operation.get("tags",[]),
            "biz_category":biz_cat,"biz_score":biz_score,"matched_kw":matched_kw,
            "is_public":True,"total_score":total_score,
            "params":[p.get("name","") for p in (operation.get("parameters") or [])],
            "auth_required":"security" in operation or "security" in spec
        }
        endpoints.append(entry)
        summary["total"] += 1
        summary["by_category"][biz_cat] = summary["by_category"].get(biz_cat,0)+1
        summary["by_method"][method.upper()] = summary["by_method"].get(method.upper(),0)+1
        if total_score >= 5:
            summary["high_risk"].append(full_path+" ["+method.upper()+"] score="+str(total_score))

SERVER_FILE = WS + "/src/server.ts"
if os.path.exists(SERVER_FILE):
    with open(SERVER_FILE, encoding="utf-8", errors="replace") as f:
        content = f.read()
    patterns = re.findall("app\\\\.(get|post|put|patch|delete)\\\\s*\\\\(\\\\s*[\'\\"]([^\'\\"]+)[\'\\"]", content)
    server_count = 0
    for method, path in patterns:
        if any(ep["path"]==path and ep["method"]==method.upper() for ep in endpoints):
            continue
        biz_score, biz_cat, matched_kw = get_biz_score(path)
        total_score = biz_score + 2
        endpoints.append({
            "path":path,"method":method.upper(),"summary":"","tags":[],
            "biz_category":biz_cat,"biz_score":biz_score,"matched_kw":matched_kw,
            "is_public":True,"total_score":total_score,"params":[],"auth_required":False,"source":"server.ts"
        })
        summary["total"] += 1
        summary["by_category"][biz_cat] = summary["by_category"].get(biz_cat,0)+1
        summary["by_method"][method.upper()] = summary["by_method"].get(method.upper(),0)+1
        if total_score >= 5:
            summary["high_risk"].append(path+" ["+method.upper()+"] score="+str(total_score)+" (server.ts)")
        server_count += 1
    print("[server.ts] " + str(server_count) + " routes added")

endpoints.sort(key=lambda x: x["total_score"], reverse=True)
with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
    json.dump({"endpoints":endpoints,"summary":summary}, f, indent=2, ensure_ascii=False)
print("total endpoints=" + str(summary["total"]))
print("high_risk count=" + str(len(summary["high_risk"])))
